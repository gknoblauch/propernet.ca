---
const principles = [
  {
    num: '01',
    title: 'Your network should be invisible.',
    description: 'Everything just works — Wi-Fi in every room, devices that connect instantly, no rebooting the router.',
  },
  {
    num: '02',
    title: 'Devices access only what they need.',
    description: 'Cameras don\'t talk to laptops. IoT gear lives on its own segment. Guests get internet, not your network.',
  },
  {
    num: '03',
    title: 'Local control over cloud dependency.',
    description: 'The network works if the cloud disappears. Your data doesn\'t leave unless you choose it to.',
  },
  {
    num: '04',
    title: 'Built to last, not to be replaced.',
    description: 'Professional hardware with a multi-year lifespan. No planned obsolescence.',
  },
];
---

<section id="approach" class="py-24 px-6">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-16 text-center">How I Approach It</h2>
    <div class="space-y-12">
      {principles.map(p => (
        <div class="flex gap-6 items-start">
          <span class="text-accent font-bold text-2xl shrink-0 w-12">{p.num}</span>
          <div>
            <h3 class="text-xl font-semibold text-white mb-2">{p.title}</h3>
            <p class="text-gray-400 leading-relaxed">{p.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
