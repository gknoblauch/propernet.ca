---
---

<section id="contact" class="py-24 px-6">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6 font-heading">Ready for a network that works?</h2>
      <p class="text-gray-400 text-lg leading-relaxed">
        A free 30-minute consultation to talk through your home, what's not working, and what a proper setup would look like. No commitment required.
      </p>
    </div>

    <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="space-y-6">
      <input type="hidden" name="access_key" value="ccac6875-755f-4490-8391-11436e4638a4" />
      <input type="hidden" name="subject" value="New consultation request from propernet.ca" />
      <input type="checkbox" name="botcheck" class="hidden" />

      <!-- Name & Email -->
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <label for="name" class="block text-sm text-gray-400 mb-1">Name <span class="text-accent">*</span></label>
          <input
            type="text"
            name="name"
            id="name"
            required
            class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            placeholder="Your name"
          />
        </div>
        <div>
          <label for="email" class="block text-sm text-gray-400 mb-1">Email <span class="text-accent">*</span></label>
          <input
            type="email"
            name="email"
            id="email"
            required
            class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            placeholder="you@example.com"
          />
        </div>
      </div>

      <!-- Phone & Property Type -->
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <label for="phone" class="block text-sm text-gray-400 mb-1">Phone</label>
          <input
            type="tel"
            name="phone"
            id="phone"
            class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
            placeholder="(780) 555-0000"
          />
        </div>
        <div>
          <label for="home_type" class="block text-sm text-gray-400 mb-1">Property type <span class="text-accent">*</span></label>
          <select
            name="home_type"
            id="home_type"
            required
            class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
          >
            <option value="" disabled selected class="bg-[#0f172a]">Select...</option>
            <option value="House" class="bg-[#0f172a]">House</option>
            <option value="Townhouse" class="bg-[#0f172a]">Townhouse</option>
            <option value="Condo" class="bg-[#0f172a]">Condo</option>
            <option value="Acreage / Rural" class="bg-[#0f172a]">Acreage / Rural</option>
            <option value="Small Business" class="bg-[#0f172a]">Small Business</option>
            <option value="Other" class="bg-[#0f172a]">Other</option>
          </select>
        </div>
      </div>

      <!-- Message -->
      <div>
        <label for="message" class="block text-sm text-gray-400 mb-1">What's going on with your network? <span class="text-accent">*</span></label>
        <textarea
          name="message"
          id="message"
          required
          rows="4"
          class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent resize-y"
          placeholder="Dead zones, slow speeds, new build that needs wiring — whatever it is, just describe it here."
        ></textarea>
      </div>

      <!-- Submit -->
      <div class="pt-2">
        <button
          type="submit"
          class="w-full md:w-auto bg-accent text-black font-semibold px-8 py-4 rounded-lg text-lg hover:bg-accent/90 transition-colors cursor-pointer"
        >
          Request a Free Consultation
        </button>
      </div>
    </form>

    <!-- Success message (hidden by default) -->
    <div id="form-success" class="hidden text-center py-12">
      <div class="text-accent text-5xl mb-4">✓</div>
      <h3 class="text-2xl font-bold text-white mb-2 font-heading">Request received</h3>
      <p class="text-gray-400">Thanks for reaching out. I'll get back to you within one business day.</p>
    </div>

    <!-- Error message (hidden by default) -->
    <div id="form-error" class="hidden text-center py-8">
      <p class="text-red-400">Something went wrong. Please try again or email directly.</p>
    </div>

    <p class="text-center text-gray-500 text-sm mt-8">
      Or email directly at
      <a href="mailto:hello@propernet.ca" class="text-accent hover:underline">hello@propernet.ca</a>
    </p>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success')!;
  const error = document.getElementById('form-error')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending...';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
      });

      if (res.ok) {
        window.location.href = '/thank-you';
      } else {
        error.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = 'Request a Free Consultation';
      }
    } catch {
      error.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Request a Free Consultation';
    }
  });
</script>
