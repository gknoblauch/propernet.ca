---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thanks — propernet.ca" description="Your consultation request has been received.">
  <main class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center max-w-md">
      <div class="text-accent text-6xl mb-6">✓</div>
      <h1 class="text-3xl font-bold text-white mb-4">Request received</h1>
      <p class="text-gray-400 text-lg mb-8">
        Thanks for reaching out. I'll get back to you within one business day.
      </p>
      <a
        href="/"
        class="inline-block bg-accent text-black font-semibold px-6 py-3 rounded-lg hover:bg-accent/90 transition-colors"
      >
        Back to home
      </a>
    </div>
  </main>
</Layout>
